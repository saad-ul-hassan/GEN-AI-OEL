  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📁 2. Dataset Loading — Penn Treebank"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Download Penn Treebank dataset\n",
    "import urllib.request\n",
    "import os\n",
    "\n",
    "os.makedirs('data', exist_ok=True)\n",
    "os.makedirs('checkpoints', exist_ok=True)\n",
    "os.makedirs('results', exist_ok=True)\n",
    "\n",
    "PTB_URLS = {\n",
    "    'train': 'https://raw.githubusercontent.com/wojzaremba/lstm/master/data/ptb.train.txt',\n",
    "    'valid': 'https://raw.githubusercontent.com/wojzaremba/lstm/master/data/ptb.valid.txt',\n",
    "    'test':  'https://raw.githubusercontent.com/wojzaremba/lstm/master/data/ptb.test.txt'\n",
    "}\n",
    "\n",
    "for split, url in PTB_URLS.items():\n",
    "    path = f'data/ptb.{split}.txt'\n",
    "    if not os.path.exists(path):\n",
    "        urllib.request.urlretrieve(url, path)\n",
    "        print(f'Downloaded: {path}')\n",
    "    else:\n",
    "        print(f'Already exists: {path}')\n",
    "\n",
    "def read_ptb(path):\n",
    "    with open(path, 'r') as f:\n",
    "        return f.read().replace('\\n', '<eos>').split()\n",
    "\n",
    "train_words = read_ptb('data/ptb.train.txt')\n",
    "valid_words = read_ptb('data/ptb.valid.txt')\n",
    "test_words  = read_ptb('data/ptb.test.txt')\n",
    "\n",
    "print(f'Train tokens : {len(train_words):,}')\n",
    "print(f'Valid tokens : {len(valid_words):,}')\n",
    "print(f'Test tokens  : {len(test_words):,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build vocabulary\n",
    "class Vocabulary:\n",
    "    def __init__(self, tokens, max_vocab=10000):\n",
    "        counter = Counter(tokens)\n",
    "        most_common = counter.most_common(max_vocab - 2)\n",
    "        self.word2idx = {'<pad>': 0, '<unk>': 1}\n",
    "        for word, _ in most_common:\n",
    "            self.word2idx[word] = len(self.word2idx)\n",
    "        self.idx2word = {v: k for k, v in self.word2idx.items()}\n",
    "        self.vocab_size = len(self.word2idx)\n",
    "\n",
    "    def encode(self, tokens):\n",
    "        return [self.word2idx.get(t, 1) for t in tokens]\n",
    "\n",
    "vocab = Vocabulary(train_words, max_vocab=10000)\n",
    "print(f'Vocabulary size: {vocab.vocab_size:,}')\n",
    "\n",
    "train_ids = torch.tensor(vocab.encode(train_words), dtype=torch.long)\n",
    "valid_ids = torch.tensor(vocab.encode(valid_words), dtype=torch.long)\n",
    "test_ids  = torch.tensor(vocab.encode(test_words),  dtype=torch.long)\n",
    "\n",
    "# Save vocab for Streamlit\n",
    "with open('results/vocab.pkl', 'wb') as f:\n",
    "    pickle.dump(vocab, f)\n",
    "\n",
    "print('Vocab saved for Streamlit app.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔧 3. Dataset & Model Definitions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SequenceDataset(Dataset):\n",
    "    \"\"\"Sliding-window language modelling dataset.\"\"\"\n",
    "    def __init__(self, token_ids: torch.Tensor, seq_len: int, stride: int = None):\n",
    "        self.seq_len = seq_len\n",
    "        stride = stride or max(1, seq_len // 2)\n",
    "        self.samples = []\n",
    "        for start in range(0, len(token_ids) - seq_len - 1, stride):\n",
    "            x = token_ids[start : start + seq_len]\n",
    "            y = token_ids[start + 1 : start + seq_len + 1]\n",
    "            self.samples.append((x, y))\n",
    "\n",
    "    def __len__(self): return len(self.samples)\n",
    "    def __getitem__(self, idx): return self.samples[idx]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class LSTMLanguageModel(nn.Module):\n",
    "    \"\"\"\n",
    "    Standardized LSTM Language Model.\n",
    "    Architecture kept CONSTANT across all configs — only seq_len varies.\n",
    "    \"\"\"\n",
    "    def __init__(self, vocab_size, embed_dim=128, hidden_size=256,\n",
    "                 num_layers=2, dropout=0.3):\n",
    "        super().__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=0)\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size=embed_dim,\n",
    "            hidden_size=hidden_size,\n",
    "            num_layers=num_layers,\n",
    "            batch_first=True,\n",
    "            dropout=dropout if num_layers > 1 else 0.0\n",
    "        )\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        self.fc = nn.Linear(hidden_size, vocab_size)\n",
    "        self._init_weights()\n",
    "\n",
    "    def _init_weights(self):\n",
    "        nn.init.uniform_(self.embedding.weight, -0.1, 0.1)\n",
    "        nn.init.zeros_(self.fc.bias)\n",
    "        nn.init.uniform_(self.fc.weight, -0.1, 0.1)\n",
    "\n",
    "    def forward(self, x, hidden=None):\n",
    "        emb = self.dropout(self.embedding(x))          # (B, T, E)\n",
    "        out, hidden = self.lstm(emb, hidden)           # (B, T, H)\n",
    "        out = self.dropout(out)\n",
    "        logits = self.fc(out)                          # (B, T, V)\n",
    "        return logits, hidden\n",
    "\n",
    "# Print model summary (for seq_len=50 as example)\n",
    "sample_model = LSTMLanguageModel(vocab.vocab_size)\n",
    "print(summary(sample_model, input_size=(32, 50), dtypes=[torch.long], device='cpu', verbose=0))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🏋️ 4. Training & Evaluation Loops"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_epoch(model, loader, optimizer, criterion, clip=1.0):\n",
    "    model.train()\n",
    "    total_loss, total_tokens = 0.0, 0\n",
    "    start = time.time()\n",
    "    for x, y in loader:\n",
    "        x, y = x.to(device), y.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        logits, _ = model(x)\n",
    "        loss = criterion(logits.view(-1, logits.size(-1)), y.view(-1))\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), clip)\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item() * y.numel()\n",
    "        total_tokens += y.numel()\n",
    "    elapsed = time.time() - start\n",
    "    return total_loss / total_tokens, elapsed\n",
    "\n",
    "\n",
    "def evaluate(model, loader, criterion):\n",
    "    model.eval()\n",
    "    total_loss, total_tokens = 0.0, 0\n",
    "    with torch.no_grad():\n",
    "        for x, y in loader:\n",
    "            x, y = x.to(device), y.to(device)\n",
    "            logits, _ = model(x)\n",
    "            loss = criterion(logits.view(-1, logits.size(-1)), y.view(-1))\n",
    "            total_loss += loss.item() * y.numel()\n",
    "            total_tokens += y.numel()\n",
    "    avg_loss = total_loss / total_tokens\n",
    "    return avg_loss, math.exp(avg_loss)  # loss, perplexity\n",
    "\n",
    "\n",
    "def get_gpu_memory_mb():\n",
    "    if device.type == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "        return torch.cuda.memory_allocated() / 1e6\n",
    "    return 0.0\n",
    "\n",
    "\n",
    "def compute_context_retention(model, token_ids, seq_len, n_samples=100):\n",
    "    \"\"\"\n",
    "    Context Retention Score:\n",
    "    For each sample, we mask the last token and ask the model to predict it\n",
    "    given the full preceding context. Higher accuracy = better retention.\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    correct, total = 0, 0\n",
    "    indices = np.random.randint(seq_len, len(token_ids) - 1, n_samples)\n",
    "    with torch.no_grad():\n",
    "        for idx in indices:\n",
    "            context = token_ids[idx - seq_len : idx].unsqueeze(0).to(device)\n",
    "            target  = token_ids[idx].item()\n",
    "            logits, _ = model(context)\n",
    "            pred = logits[0, -1, :].argmax().item()\n",
    "            if pred == target:\n",
    "                correct += 1\n",
    "            total += 1\n",
    "    return correct / total"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔬 5. Experimental Configurations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Experimental Configurations ──────────────────────────────────────────────\n",
    "CONFIGS = [\n",
    "    {'name': 'C1 — Short',     'seq_len': 15,  'batch_size': 128, 'label': 'C1'},\n",
    "    {'name': 'C2 — Medium',    'seq_len': 75,  'batch_size': 64,  'label': 'C2'},\n",
    "    {'name': 'C3 — Long',      'seq_len': 300, 'batch_size': 16,  'label': 'C3'},\n",
    "    {'name': 'C4 — Very Long', 'seq_len': 600, 'batch_size': 8,   'label': 'C4'},\n",
    "]\n",
    "\n",
    "# ── Fixed Hyperparameters ─────────────────────────────────────────────────────\n",
    "NUM_EPOCHS   = 10      # Increase to 20-30 for better convergence\n",
    "LEARNING_RATE = 0.001\n",
    "EMBED_DIM    = 128\n",
    "HIDDEN_SIZE  = 256\n",
    "NUM_LAYERS   = 2\n",
    "DROPOUT      = 0.3\n",
    "GRAD_CLIP    = 1.0\n",
    "\n",
    "print('Experimental Configurations:')\n",
    "for c in CONFIGS:\n",
    "    print(f\"  {c['label']} | seq_len={c['seq_len']:4d} | batch={c['batch_size']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🚀 6. Run All Experiments"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "all_results = {}\n",
    "\n",
    "for cfg in CONFIGS:\n",
    "    label    = cfg['label']\n",
    "    seq_len  = cfg['seq_len']\n",
    "    bs       = cfg['batch_size']\n",
    "    cfg_name = cfg['name']\n",
    "\n",
    "    print(f'\\n{'='*60}')\n",
    "    print(f'  Running: {cfg_name}  (seq_len={seq_len}, batch={bs})')\n",
    "    print(f'{'='*60}')\n",
    "\n",
    "    # ── Datasets & Loaders ────────────────────────────────────────\n",
    "    train_ds = SequenceDataset(train_ids, seq_len)\n",
    "    valid_ds = SequenceDataset(valid_ids, seq_len)\n",
    "    test_ds  = SequenceDataset(test_ids,  seq_len)\n",
    "\n",
    "    train_loader = DataLoader(train_ds, batch_size=bs, shuffle=True,  num_workers=2, pin_memory=True)\n",
    "    valid_loader = DataLoader(valid_ds, batch_size=bs, shuffle=False, num_workers=2, pin_memory=True)\n",
    "    test_loader  = DataLoader(test_ds,  batch_size=bs, shuffle=False, num_workers=2, pin_memory=True)\n",
    "\n",
    "    print(f'  Train batches: {len(train_loader):,} | Valid batches: {len(valid_loader):,}')\n",
    "\n",
    "    # ── Model ─────────────────────────────────────────────────────\n",
    "    model = LSTMLanguageModel(\n",
    "        vocab_size=vocab.vocab_size,\n",
    "        embed_dim=EMBED_DIM,\n",
    "        hidden_size=HIDDEN_SIZE,\n",
    "        num_layers=NUM_LAYERS,\n",
    "        dropout=DROPOUT\n",
    "    ).to(device)\n",
    "\n",
    "    optimizer = optim.Adam(model.parameters(), lr=LEARNING_RATE)\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=2, factor=0.5)\n",
    "    criterion = nn.CrossEntropyLoss(ignore_index=0)\n",
    "\n",
    "    if USE_WANDB:\n",
    "        wandb.init(project='lstm-context-window', name=label, config=cfg)\n",
    "\n",
    "    # ── Training Loop ─────────────────────────────────────────────\n",
    "    history = {'train_loss': [], 'valid_loss': [], 'valid_ppl': [],\n",
    "               'epoch_time': [], 'gpu_memory_mb': []}\n",
    "\n",
    "    best_valid_loss = float('inf')\n",
    "\n",
    "    for epoch in range(1, NUM_EPOCHS + 1):\n",
    "        torch.cuda.reset_peak_memory_stats() if device.type == 'cuda' else None\n",
    "\n",
    "        train_loss, epoch_time = train_epoch(model, train_loader, optimizer, criterion, GRAD_CLIP)\n",
    "        valid_loss, valid_ppl  = evaluate(model, valid_loader, criterion)\n",
    "        scheduler.step(valid_loss)\n",
    "\n",
    "        mem_mb = (torch.cuda.max_memory_allocated() / 1e6\n",
    "                  if device.type == 'cuda' else 0.0)\n",
    "\n",
    "        history['train_loss'].append(train_loss)\n",
    "        history['valid_loss'].append(valid_loss)\n",
    "        history['valid_ppl'].append(valid_ppl)\n",
    "        history['epoch_time'].append(epoch_time)\n",
    "        history['gpu_memory_mb'].append(mem_mb)\n",
    "\n",
    "        print(f'  Epoch {epoch:2d}/{NUM_EPOCHS} | '\n",
    "              f'Train Loss: {train_loss:.4f} | '\n",
    "              f'Valid Loss: {valid_loss:.4f} | '\n",
    "              f'PPL: {valid_ppl:7.2f} | '\n",
    "              f'Time: {epoch_time:5.1f}s | '\n",
    "              f'Mem: {mem_mb:.0f}MB')\n",
    "\n",
    "        if USE_WANDB:\n",
    "            wandb.log({'train_loss': train_loss, 'valid_loss': valid_loss,\n",
    "                       'valid_ppl': valid_ppl, 'gpu_memory_mb': mem_mb})\n",
    "\n",
    "        if valid_loss < best_valid_loss:\n",
    "            best_valid_loss = valid_loss\n",
    "            torch.save(model.state_dict(), f'checkpoints/model_{label}.pt')\n",
    "\n",
    "    # ── Final Evaluation ──────────────────────────────────────────\n",
    "    model.load_state_dict(torch.load(f'checkpoints/model_{label}.pt'))\n",
    "    test_loss, test_ppl = evaluate(model, test_loader, criterion)\n",
    "    retention_score     = compute_context_retention(model, test_ids, seq_len)\n",
    "\n",
    "    print(f'\\n  ✅ {cfg_name} FINAL:')\n",
    "    print(f'     Test Loss      : {test_loss:.4f}')\n",
    "    print(f'     Test Perplexity: {test_ppl:.2f}')\n",
    "    print(f'     Retention Score: {retention_score:.4f}')\n",
    "\n",
    "    all_results[label] = {\n",
    "        'config'          : cfg,\n",
    "        'history'         : history,\n",
    "        'test_loss'       : test_loss,\n",
    "        'test_ppl'        : test_ppl,\n",
    "        'retention_score' : retention_score,\n",
    "        'avg_epoch_time'  : np.mean(history['epoch_time']),\n",
    "        'avg_gpu_memory'  : np.mean(history['gpu_memory_mb']),\n",
    "        'best_valid_loss' : best_valid_loss,\n",
    "    }\n",
    "\n",
    "    if USE_WANDB:\n",
    "        wandb.finish()\n",
    "\n",
    "# Save results\n",
    "with open('results/all_results.json', 'w') as f:\n",
    "    # Convert numpy floats for JSON serialization\n",
    "    def convert(o):\n",
    "        if isinstance(o, (np.float32, np.float64)): return float(o)\n",
    "        if isinstance(o, (np.int32, np.int64)):     return int(o)\n",
    "        raise TypeError\n",
    "    json.dump(all_results, f, indent=2, default=convert)\n",
    "\n",
    "print('\\n✅ All experiments complete. Results saved to results/all_results.json')"
   ]
  },
  {
