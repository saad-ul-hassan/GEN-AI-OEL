    "    'grid.color'      : '#21262d',\n",
    "    'grid.linewidth'  : 0.8,\n",
    "    'font.family'     : 'monospace',\n",
    "    'font.size'       : 10,\n",
    "})\n",
    "\n",
    "PALETTE = ['#58a6ff', '#3fb950', '#f78166', '#d2a8ff']\n",
    "LABELS   = [r['config']['name'] for r in all_results.values()]\n",
    "SEQ_LENS = [r['config']['seq_len'] for r in all_results.values()]\n",
    "\n",
    "fig = plt.figure(figsize=(20, 16))\n",
    "fig.suptitle('LSTM Context Window Impact Study — Results Dashboard',\n",
    "             fontsize=18, fontweight='bold', color='#e6edf3', y=0.98)\n",
    "gs = gridspec.GridSpec(3, 3, figure=fig, hspace=0.45, wspace=0.35)\n",
    "\n",
    "# ── Plot 1: Learning Curves (Validation Loss) ─────────────────────────────────\n",
    "ax1 = fig.add_subplot(gs[0, :])\n",
    "for i, (lbl, res) in enumerate(all_results.items()):\n",
    "    epochs = range(1, len(res['history']['valid_loss']) + 1)\n",
    "    ax1.plot(epochs, res['history']['valid_loss'],\n",
    "             color=PALETTE[i], linewidth=2.2,\n",
    "             marker='o', markersize=4,\n",
    "             label=res['config']['name'])\n",
    "ax1.set_title('Validation Loss — Learning Curves', fontweight='bold')\n",
    "ax1.set_xlabel('Epoch')\n",
    "ax1.set_ylabel('Cross-Entropy Loss')\n",
    "ax1.legend(loc='upper right')\n",
    "ax1.grid(True)\n",
    "\n",
    "# ── Plot 2: Test Perplexity ───────────────────────────────────────────────────\n",
    "ax2 = fig.add_subplot(gs[1, 0])\n",
