   "source": [
    "# ── Style ─────────────────────────────────────────────────────────────────────\n",
    "plt.rcParams.update({\n",
    "    'figure.facecolor': '#0d1117',\n",
    "    'axes.facecolor'  : '#161b22',\n",
    "    'axes.edgecolor'  : '#30363d',\n",
    "    'axes.labelcolor' : '#e6edf3',\n",
    "    'text.color'      : '#e6edf3',\n",
    "    'xtick.color'     : '#8b949e',\n",
