    "## 🔥 8. Hidden State Activation Heatmaps"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_hidden_heatmap(model, token_ids, seq_len, config_name, n_tokens=80):\n",
    "    \"\"\"Visualize hidden state activations across time steps.\"\"\"\n",
    "    model.eval()\n",
    "    sample = token_ids[:seq_len].unsqueeze(0).to(device)\n",
    "\n",
    "    activations = []\n",
    "    hooks = []\n",
    "\n",
    "    def hook_fn(module, input, output):\n",
    "        activations.append(output[0].detach().cpu())\n",
    "\n",
    "    h = model.lstm.register_forward_hook(hook_fn)\n",
    "    with torch.no_grad():\n",
    "        _ = model(sample)\n",
    "    h.remove()\n",
    "\n",
    "    hidden = activations[0][0]  # (T, H)\n",
    "    hidden_np = hidden[:n_tokens, :64].numpy()  # First 64 units, first n_tokens steps\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(14, 4), facecolor='#0d1117')\n",
    "    ax.set_facecolor('#161b22')\n",
    "    im = ax.imshow(hidden_np.T, aspect='auto', cmap='RdBu_r',\n",
    "                   vmin=-1, vmax=1, interpolation='nearest')\n",
    "    plt.colorbar(im, ax=ax, label='Activation')\n",
    "    ax.set_title(f'Hidden State Activations — {config_name}',\n",
    "                 color='#e6edf3', fontweight='bold', fontsize=13)\n",
    "    ax.set_xlabel('Time Step (token position)', color='#8b949e')\n",
    "    ax.set_ylabel('Hidden Unit Index', color='#8b949e')\n",
    "    ax.tick_params(colors='#8b949e')\n",
    "\n",
    "    fname = f\"results/heatmap_{config_name.split(' — ')[0].strip()}.png\"\n",
    "    plt.savefig(fname, dpi=120, bbox_inches='tight', facecolor='#0d1117')\n",
    "    plt.show()\n",
    "    print(f'Saved: {fname}')\n",
    "\n",
    "\n",
    "for cfg in CONFIGS:\n",
    "    lbl = cfg['label']\n",
    "    seq = cfg['seq_len']\n",
    "    m = LSTMLanguageModel(vocab.vocab_size, EMBED_DIM, HIDDEN_SIZE, NUM_LAYERS, DROPOUT).to(device)\n",
    "    m.load_state_dict(torch.load(f'checkpoints/model_{lbl}.pt'))\n",
    "    plot_hidden_heatmap(m, test_ids, seq, cfg['name'])"
   ]
  },
